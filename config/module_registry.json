      ],
      "outputs": [
        "完整 run_result"
      ],
      "dependencies": [
        "repo_context",
        "tool_runner",
        "scanner_agent",
        "validator_agent",
        "planner_agent",
        "critic_agent",
        "model_routing"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
