      "responsibility": "基于扫描 artifacts 生成原始 findings 并检测循环 import。",
      "inputs": [
        "artifacts/import_graph.json",
        "artifacts/env_usage.json",
        "artifacts/db_usage.json",
        "artifacts/utils_usage.json",
        "artifacts/global_state.json"
      ],
      "outputs": [
        "artifacts/findings.json"
      ],
      "dependencies": [
        "import_scanner",
        "env_scanner",
        "db_usage_scanner",
        "utils_usage_scanner",
        "global_state_scanner"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "tool_runner",
      "module_type": "orchestrator",
      "status": "implemented",
      "implementation_paths": [
        "agents/tool_runner.py"
      ],
      "responsibility": "运行确定性扫描器和规则引擎，产出基础 artifacts。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "基础扫描 artifacts",
        "artifacts/findings.json"
      ],
      "dependencies": [
        "repo_context",
        "import_scanner",
        "definitions_scanner",
        "call_scanner",
        "env_scanner",
        "db_usage_scanner",
        "utils_usage_scanner",
        "global_state_scanner",
        "rule_engine"
      ],
      "test_entrypoints": [
        "tests/test_goldens.py",
        "tests/test_reporting.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
