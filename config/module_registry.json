      "responsibility": "解析 provider 与 agent 模型路由配置，支持环境变量覆盖。",
      "inputs": [
        "config/agent_models.json",
        "环境变量"
      ],
      "outputs": [
        "artifacts/model_routing.json"
      ],
      "dependencies": [],
      "test_entrypoints": [
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
