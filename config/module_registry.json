      "inputs": [
        "基础扫描 artifacts",
        "validated_findings",
        "repo_inventory",
        "triage",
        "action_plan",
        "critic_review",
        "model_routing"
      ],
      "outputs": [
        "summary.md"
      ],
      "dependencies": [
        "tool_runner",
        "validator_agent",
        "scanner_agent",
        "planner_agent",
        "critic_agent",
        "model_routing"
      ],
      "test_entrypoints": [
        "tests/test_reporting.py",
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
