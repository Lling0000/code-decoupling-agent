      "module_type": "agent_support",
      "status": "implemented",
      "implementation_paths": [
        "agents/module_report_agent.py"
      ],
      "responsibility": "生成全仓模块画像、P0/P1/P2 优先级排序，并为重点模块产出模块诊断卡。",
      "inputs": [
        "RepoContext",
        "基础扫描 artifacts",
        "artifacts/validated_findings.json"
      ],
      "outputs": [
        "artifacts/module_inventory.json",
        "artifacts/module_priorities.json",
        "artifacts/module_deep_reviews.json",
        "module_reports/lightweight/*.md",
        "module_reports/heavyweight/*.md"
      ],
      "dependencies": [
        "tool_runner",
        "validator_agent"
      ],
      "test_entrypoints": [
        "tests/test_module_reports.py",
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "gate_runner",
      "module_type": "guardrail",
      "status": "implemented",
      "implementation_paths": [
        "iteration/gate_runner.py",
        "config/gate_spec.json"
      ],
      "responsibility": "执行测试门禁、策略门禁和运行门禁，产出 agent/human 双门禁报告。",
      "inputs": [
        "仓库路径",
        "输出目录",
        "artifacts/action_plan.json",
        "artifacts/critic_review.json",
        "config/gate_spec.json"
      ],
      "outputs": [
        "artifacts/iteration_agent_report.json",
        "iteration_human_report.md"
      ],
      "dependencies": [
        "policy_engine"
      ],
      "test_entrypoints": [
        "tests/test_gate_runner.py",
        "tests/test_design_specs.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "cli_entrypoint",
      "module_type": "entrypoint",
      "status": "implemented",
      "implementation_paths": [
        "main.py"
      ],
      "responsibility": "提供 CLI 入口，写出所有 artifacts 和 summary，并支持 LLM 自检。",
      "inputs": [
        "--repo",
        "--output",
        "--check-llm-config"
      ],
      "outputs": [
        "summary.md",
        "artifacts/*.json",
        "iteration_human_report.md"
      ],
      "dependencies": [
        "governor",
        "report_renderer",
        "module_report_agent",
        "llm_health",
        "gate_runner"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    }
