      "inputs": [
        "artifacts/action_plan.json",
        "artifacts/repo_inventory.json",
        "model_routing"
      ],
      "outputs": [
        "artifacts/critic_review.json",
        "artifacts/critic_agent.json"
      ],
      "dependencies": [
        "planner_agent",
        "policy_engine",
        "model_routing"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_reporting.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "policy_engine",
      "module_type": "guardrail",
      "status": "implemented",
      "implementation_paths": [
        "policy/engine.py"
      ],
      "responsibility": "对计划范围和受保护路径做确定性门禁检查。",
      "inputs": [
        "artifacts/action_plan.json"
      ],
      "outputs": [
        "policy evaluation result"
      ],
      "dependencies": [],
      "test_entrypoints": [
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
