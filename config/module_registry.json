      "module_type": "llm_support",
      "status": "implemented",
      "implementation_paths": [
        "llm/health.py",
        "llm/client.py",
        "llm/env.py"
      ],
      "responsibility": "检查 LLM provider 配置、live 开关和模型探活状态。",
      "inputs": [
        "model_routing",
