      "responsibility": "基于 actionable findings 生成 triage 和受控 action plan。",
      "inputs": [
        "artifacts/validated_findings.json",
        "artifacts/repo_inventory.json",
        "model_routing"
      ],
      "outputs": [
        "artifacts/triage.json",
        "artifacts/action_plan.json",
        "artifacts/planner_agent.json"
      ],
      "dependencies": [
        "validator_agent",
        "scanner_agent",
        "model_routing"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_reporting.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
