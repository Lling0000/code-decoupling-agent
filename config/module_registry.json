      "dependencies": [
        "tool_runner",
        "model_routing"
      ],
      "test_entrypoints": [
        "tests/test_validator_agent.py",
        "tests/test_reporting.py",
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "planner_agent",
      "module_type": "agent",
      "status": "implemented",
      "implementation_paths": [
        "agents/planner_agent.py"
