      "module_type": "context_builder",
      "status": "implemented",
      "implementation_paths": [
        "scanner/__init__.py",
        "models/schema.py"
      ],
      "responsibility": "构建 RepoContext，收集 Python 文件、模块索引和解析错误。",
      "inputs": [
        "仓库根目录路径"
      ],
      "outputs": [
        "RepoContext"
      ],
      "dependencies": [],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "import_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/imports.py"
      ],
      "responsibility": "扫描 import 关系，建立本地依赖边和循环依赖输入。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/import_graph.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "definitions_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/definitions.py"
      ],
      "responsibility": "扫描类、函数和方法定义。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/definitions.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_reporting.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "call_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/calls.py"
      ],
      "responsibility": "提取近似调用边，生成 call graph。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/call_graph.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_reporting.py",
        "tests/test_smoke.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "env_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/envs.py"
      ],
      "responsibility": "识别常见环境变量读取模式。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/env_usage.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "db_usage_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/db_usage.py"
      ],
      "responsibility": "识别数据库和 ORM 使用信号，并尽量做来源证明。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/db_usage.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "utils_usage_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/utils_usage.py"
      ],
      "responsibility": "统计本地 utils/common/helper 模块的依赖范围。",
      "inputs": [
        "artifacts/import_graph.json"
      ],
      "outputs": [
        "artifacts/utils_usage.json"
      ],
      "dependencies": [
        "import_scanner"
      ],
      "test_entrypoints": [
        "tests/test_smoke.py",
        "tests/test_goldens.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "global_state_scanner",
      "module_type": "scanner",
      "status": "implemented",
      "implementation_paths": [
        "scanner/globals.py"
      ],
      "responsibility": "识别模块级可变状态及其函数内变更证据。",
      "inputs": [
        "RepoContext"
      ],
      "outputs": [
        "artifacts/global_state.json"
      ],
      "dependencies": [
        "repo_context"
      ],
      "test_entrypoints": [
        "tests/test_goldens.py",
        "tests/test_validator_agent.py"
      ],
      "readme_required": true,
      "readme_template_path": "templates/module_README.md"
    },
    {
      "module_id": "rule_engine",
      "module_type": "rules_engine",
      "status": "implemented",
      "implementation_paths": [
        "rules_engine/engine.py",
        "rules/config.py"
